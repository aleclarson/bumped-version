{
  "name": "bumped-version",
  "version": "0.1.0",
  "license": "MIT OR Apache-2.0",
  "author": "Alec Larson",
  "repository": {
    "type": "git",
    "url": "https://github.com/aleclarson/bumped-version.git"
  },
  "bin": {
    "bumped-version": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "docs",
    "examples"
  ],
  "type": "module",
  "exports": {
    "types": "./dist/index.d.mts",
    "default": "./dist/index.mjs"
  },
  "scripts": {
    "dev": "tsdown --sourcemap --watch",
    "build": "tsdown",
    "format": "oxfmt .",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit && tsc -p test --noEmit",
    "test": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "radashi": "^12.9.1",
    "tsdown": "^0.22.2",
    "tsnapi": "^0.3.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.5.1"
}
